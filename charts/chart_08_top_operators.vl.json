{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 560,
  "height": 320,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "title": {
    "text": "Top 10 operators by capacity",
    "subtitle": "Lollipop length shows total capacity. The four largest hold 74% of the national total."
  },
  "data": {
    "url": "data/data_centres.csv"
  },
  "transform": [
    {
      "aggregate": [
        {
          "op": "sum",
          "field": "capacity_mw",
          "as": "total_mw"
        },
        {
          "op": "count",
          "as": "sites"
        }
      ],
      "groupby": [
        "operator",
        "operator_type"
      ]
    },
    {
      "window": [
        {
          "op": "rank",
          "as": "rank"
        }
      ],
      "sort": [
        {
          "field": "total_mw",
          "order": "descending"
        }
      ]
    },
    {
      "filter": "datum.rank <= 10"
    }
  ],
  "encoding": {
    "y": {
      "field": "operator",
      "type": "nominal",
      "sort": "-x",
      "title": null,
      "axis": {
        "labelFontWeight": 500,
        "labelColor": "#161616"
      }
    },
    "opacity": {
      "condition": {
        "param": "hl8",
        "value": 1,
        "empty": true
      },
      "value": 0.35
    }
  },
  "layer": [
    {
      "mark": {
        "type": "rule",
        "strokeWidth": 2
      },
      "encoding": {
        "x": {
          "field": "total_mw",
          "type": "quantitative",
          "title": "Capacity (MW)",
          "scale": {
            "domain": [
              0,
              420
            ]
          }
        },
        "color": {
          "field": "operator_type",
          "type": "nominal",
          "scale": {
            "domain": [
              "Foreign Hyperscaler",
              "Foreign",
              "Domestic"
            ],
            "range": [
              "#E0584F",
              "#F39C42",
              "#1F8B8A"
            ]
          },
          "legend": {
            "orient": "top",
            "title": "Ownership"
          }
        }
      },
      "params": [
        {
          "name": "hl8",
          "select": {
            "type": "point",
            "on": "mouseover",
            "fields": [
              "operator"
            ],
            "clear": "mouseout"
          }
        }
      ]
    },
    {
      "mark": {
        "type": "circle",
        "size": 180,
        "stroke": "white",
        "strokeWidth": 1
      },
      "encoding": {
        "x": {
          "field": "total_mw",
          "type": "quantitative"
        },
        "color": {
          "field": "operator_type",
          "type": "nominal",
          "scale": {
            "domain": [
              "Foreign Hyperscaler",
              "Foreign",
              "Domestic"
            ],
            "range": [
              "#E0584F",
              "#F39C42",
              "#1F8B8A"
            ]
          },
          "legend": null
        },
        "tooltip": [
          {
            "field": "operator",
            "type": "nominal",
            "title": "Operator"
          },
          {
            "field": "operator_type",
            "type": "nominal",
            "title": "Type"
          },
          {
            "field": "total_mw",
            "type": "quantitative",
            "title": "Capacity (MW)",
            "format": ".1f"
          },
          {
            "field": "sites",
            "type": "quantitative",
            "title": "Facilities"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 12,
        "fontSize": 10,
        "fontWeight": 600,
        "color": "#161616"
      },
      "encoding": {
        "x": {
          "field": "total_mw",
          "type": "quantitative"
        },
        "text": {
          "field": "total_mw",
          "type": "quantitative",
          "format": ".0f"
        }
      }
    }
  ],
  "config": {
    "background": "transparent",
    "view": {
      "stroke": null
    },
    "font": "Hanken Grotesk, system-ui, sans-serif",
    "axis": {
      "labelFont": "Hanken Grotesk, system-ui, sans-serif",
      "labelFontSize": 11,
      "labelColor": "#54544F",
      "titleFont": "Hanken Grotesk, system-ui, sans-serif",
      "titleFontSize": 11,
      "titleColor": "#161616",
      "titleFontWeight": 500,
      "domain": false,
      "ticks": false,
      "grid": true,
      "gridColor": "#E5E2D9",
      "gridOpacity": 0.5,
      "labelPadding": 6
    },
    "axisX": {
      "grid": false
    },
    "legend": {
      "labelFont": "Hanken Grotesk, system-ui, sans-serif",
      "labelFontSize": 11,
      "titleFont": "Hanken Grotesk, system-ui, sans-serif",
      "titleFontSize": 11,
      "titleFontWeight": 500,
      "symbolType": "circle"
    },
    "title": {
      "font": "Hanken Grotesk, system-ui, sans-serif",
      "fontSize": 14,
      "fontWeight": 600,
      "color": "#161616",
      "anchor": "start",
      "offset": 8,
      "subtitleFont": "Hanken Grotesk, system-ui, sans-serif",
      "subtitleFontSize": 11,
      "subtitleColor": "#54544F"
    }
  }
}