{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 560,
  "height": 300,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "title": {
    "text": "The latency gap: each city versus Sydney",
    "subtitle": "Each line runs from Sydney's 6.2ms baseline (grey) to that city's actual latency (purple). Longer line means a bigger penalty."
  },
  "data": {
    "url": "data/regional_latency.json"
  },
  "transform": [
    {
      "calculate": "6.2",
      "as": "baseline"
    },
    {
      "calculate": "datum.latency - 6.2",
      "as": "gap"
    }
  ],
  "encoding": {
    "y": {
      "field": "city",
      "type": "nominal",
      "sort": {
        "field": "latency",
        "order": "descending"
      },
      "title": null,
      "axis": {
        "labelFontWeight": 500,
        "labelColor": "#161616"
      }
    },
    "opacity": {
      "condition": {
        "param": "hl9",
        "value": 1,
        "empty": true
      },
      "value": 0.35
    }
  },
  "layer": [
    {
      "mark": {
        "type": "rule",
        "color": "#C9C5B8",
        "strokeWidth": 2
      },
      "encoding": {
        "x": {
          "field": "baseline",
          "type": "quantitative",
          "title": "Round-trip latency (ms)",
          "scale": {
            "domain": [
              0,
              90
            ]
          }
        },
        "x2": {
          "field": "latency"
        }
      },
      "params": [
        {
          "name": "hl9",
          "select": {
            "type": "point",
            "on": "mouseover",
            "fields": [
              "city"
            ],
            "clear": "mouseout"
          }
        }
      ]
    },
    {
      "mark": {
        "type": "circle",
        "size": 110,
        "color": "#B9B5A9",
        "stroke": "white",
        "strokeWidth": 1
      },
      "encoding": {
        "x": {
          "field": "baseline",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "city",
            "type": "nominal"
          },
          {
            "value": "Sydney baseline: 6.2ms"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "circle",
        "size": 150,
        "color": "#653A98",
        "stroke": "white",
        "strokeWidth": 1
      },
      "encoding": {
        "x": {
          "field": "latency",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "city",
            "type": "nominal",
            "title": "City"
          },
          {
            "field": "latency",
            "type": "quantitative",
            "title": "Latency (ms)",
            "format": ".1f"
          },
          {
            "field": "gap",
            "type": "quantitative",
            "title": "Penalty vs Sydney (ms)",
            "format": ".1f"
          },
          {
            "field": "city_class",
            "type": "nominal",
            "title": "Region type"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 10,
        "fontSize": 10,
        "fontWeight": 600,
        "color": "#161616"
      },
      "encoding": {
        "x": {
          "field": "latency",
          "type": "quantitative"
        },
        "text": {
          "field": "latency",
          "type": "quantitative",
          "format": ".0f"
        }
      }
    }
  ],
  "config": {
    "background": "transparent",
    "view": {
      "stroke": null
    },
    "font": "Hanken Grotesk, system-ui, sans-serif",
    "axis": {
      "labelFont": "Hanken Grotesk, system-ui, sans-serif",
      "labelFontSize": 11,
      "labelColor": "#54544F",
      "titleFont": "Hanken Grotesk, system-ui, sans-serif",
      "titleFontSize": 11,
      "titleColor": "#161616",
      "titleFontWeight": 500,
      "domain": false,
      "ticks": false,
      "grid": true,
      "gridColor": "#E5E2D9",
      "gridOpacity": 0.5,
      "labelPadding": 6
    },
    "axisX": {
      "grid": false
    },
    "legend": {
      "labelFont": "Hanken Grotesk, system-ui, sans-serif",
      "labelFontSize": 11,
      "titleFont": "Hanken Grotesk, system-ui, sans-serif",
      "titleFontSize": 11,
      "titleFontWeight": 500,
      "symbolType": "circle"
    },
    "title": {
      "font": "Hanken Grotesk, system-ui, sans-serif",
      "fontSize": 14,
      "fontWeight": 600,
      "color": "#161616",
      "anchor": "start",
      "offset": 8,
      "subtitleFont": "Hanken Grotesk, system-ui, sans-serif",
      "subtitleFontSize": 11,
      "subtitleColor": "#54544F"
    }
  }
}