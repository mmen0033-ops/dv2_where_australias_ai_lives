{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 620,
  "height": 470,
  "title": {
    "text": "The latency tax: round-trip time to the nearest hyperscaler",
    "subtitle": "Each ABS SA4 region shaded by round-trip latency. Regions without measured data are estimated from distance.",
    "anchor": "start"
  },
  "projection": {
    "type": "mercator",
    "scale": 600,
    "center": [
      134,
      -25.5
    ]
  },
  "layer": [
    {
      "data": {
        "sphere": true
      },
      "mark": {
        "type": "geoshape",
        "fill": "#E9ECEE",
        "clip": true
      }
    },
    {
      "data": {
        "graticule": {
          "step": [
            10,
            10
          ]
        }
      },
      "mark": {
        "type": "geoshape",
        "filled": false,
        "stroke": "#D8DAD6",
        "strokeWidth": 0.35,
        "strokeOpacity": 0.35,
        "clip": true
      }
    },
    {
      "data": {
        "url": "data/au_geo.topo.json",
        "format": {
          "type": "topojson",
          "feature": "au_sa4"
        }
      },
      "mark": {
        "type": "geoshape",
        "stroke": "#FFFFFF",
        "strokeWidth": 0.25,
        "clip": true
      },
      "encoding": {
        "color": {
          "field": "properties.tier",
          "type": "ordinal",
          "scale": {
            "domain": [
              "<15ms",
              "15-25ms",
              "25-50ms",
              "50-100ms"
            ],
            "range": [
              "#E6DEF2",
              "#BFA9DA",
              "#9670BD",
              "#653A98"
            ]
          },
          "title": "Round-trip latency",
          "legend": {
            "orient": "bottom",
            "direction": "horizontal",
            "offset": 8,
            "symbolType": "square"
          }
        },
        "tooltip": [
          {
            "field": "properties.label",
            "type": "nominal",
            "title": "Region"
          },
          {
            "field": "properties.state",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "properties.latency_ms",
            "type": "quantitative",
            "title": "Latency (ms)",
            "format": ".1f"
          },
          {
            "field": "properties.tier",
            "type": "nominal",
            "title": "Tier"
          },
          {
            "field": "properties.population",
            "type": "quantitative",
            "title": "Population",
            "format": ","
          }
        ],
        "opacity": {
          "condition": {
            "test": "hlState == 'All' || datum._ab == hlState",
            "value": 1
          },
          "value": 0.12
        }
      },
      "transform": [
        {
          "calculate": "datum.properties.state == 'New South Wales' ? 'NSW' : datum.properties.state == 'Victoria' ? 'VIC' : datum.properties.state == 'Queensland' ? 'QLD' : datum.properties.state == 'South Australia' ? 'SA' : datum.properties.state == 'Western Australia' ? 'WA' : datum.properties.state == 'Tasmania' ? 'TAS' : datum.properties.state == 'Northern Territory' ? 'NT' : datum.properties.state == 'Australian Capital Territory' ? 'ACT' : 'OTHER'",
          "as": "_ab"
        }
      ]
    },
    {
      "data": {
        "url": "data/au_geo.topo.json",
        "format": {
          "type": "topojson",
          "feature": "au_states"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": null,
        "stroke": "#5F5B52",
        "strokeWidth": 0.8,
        "clip": true
      }
    },
    {
      "data": {
        "values": [
          {
            "city": "Sydney",
            "lat": -33.87,
            "lon": 151.21
          },
          {
            "city": "Melbourne",
            "lat": -37.81,
            "lon": 144.96
          },
          {
            "city": "Brisbane",
            "lat": -27.47,
            "lon": 153.03
          },
          {
            "city": "Perth",
            "lat": -31.95,
            "lon": 115.86
          },
          {
            "city": "Adelaide",
            "lat": -34.93,
            "lon": 138.6
          },
          {
            "city": "Canberra",
            "lat": -35.28,
            "lon": 149.13
          }
        ]
      },
      "mark": {
        "type": "circle",
        "size": 13,
        "fill": "#2A2A28",
        "opacity": 0.85,
        "clip": true
      },
      "encoding": {
        "longitude": {
          "field": "lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "lat",
          "type": "quantitative"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "city": "Sydney",
            "lat": -33.87,
            "lon": 151.21
          },
          {
            "city": "Melbourne",
            "lat": -37.81,
            "lon": 144.96
          },
          {
            "city": "Brisbane",
            "lat": -27.47,
            "lon": 153.03
          },
          {
            "city": "Perth",
            "lat": -31.95,
            "lon": 115.86
          },
          {
            "city": "Adelaide",
            "lat": -34.93,
            "lon": 138.6
          },
          {
            "city": "Canberra",
            "lat": -35.28,
            "lon": 149.13
          }
        ]
      },
      "mark": {
        "type": "text",
        "fontSize": 10.5,
        "fontWeight": 700,
        "dy": -10,
        "align": "center",
        "stroke": "#FFFFFF",
        "strokeWidth": 3,
        "lineJoin": "round",
        "fill": "#FFFFFF",
        "clip": true
      },
      "encoding": {
        "longitude": {
          "field": "lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "lat",
          "type": "quantitative"
        },
        "text": {
          "field": "city",
          "type": "nominal"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "city": "Sydney",
            "lat": -33.87,
            "lon": 151.21
          },
          {
            "city": "Melbourne",
            "lat": -37.81,
            "lon": 144.96
          },
          {
            "city": "Brisbane",
            "lat": -27.47,
            "lon": 153.03
          },
          {
            "city": "Perth",
            "lat": -31.95,
            "lon": 115.86
          },
          {
            "city": "Adelaide",
            "lat": -34.93,
            "lon": 138.6
          },
          {
            "city": "Canberra",
            "lat": -35.28,
            "lon": 149.13
          }
        ]
      },
      "mark": {
        "type": "text",
        "fontSize": 10.5,
        "fontWeight": 700,
        "dy": -10,
        "align": "center",
        "fill": "#23231F",
        "clip": true
      },
      "encoding": {
        "longitude": {
          "field": "lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "lat",
          "type": "quantitative"
        },
        "text": {
          "field": "city",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "background": "transparent",
    "view": {
      "stroke": null
    },
    "font": "Hanken Grotesk, system-ui, sans-serif",
    "axis": {
      "labelFont": "Hanken Grotesk, system-ui, sans-serif",
      "labelFontSize": 11,
      "labelColor": "#6B6B68",
      "titleFont": "Hanken Grotesk, system-ui, sans-serif",
      "titleFontSize": 11,
      "titleColor": "#1A1A1A",
      "titleFontWeight": 500,
      "domain": false,
      "ticks": false,
      "grid": true,
      "gridColor": "#E5E2D9",
      "gridOpacity": 0.5,
      "labelPadding": 6
    },
    "axisX": {
      "grid": false
    },
    "legend": {
      "labelFont": "Hanken Grotesk, system-ui, sans-serif",
      "labelFontSize": 11,
      "titleFont": "Hanken Grotesk, system-ui, sans-serif",
      "titleFontSize": 11,
      "titleFontWeight": 500,
      "padding": 0,
      "symbolType": "circle"
    },
    "title": {
      "font": "Hanken Grotesk, system-ui, sans-serif",
      "fontSize": 14,
      "fontWeight": 600,
      "color": "#1A1A1A",
      "anchor": "start",
      "offset": 8,
      "subtitleFont": "Hanken Grotesk, system-ui, sans-serif",
      "subtitleFontSize": 11,
      "subtitleColor": "#6B6B68"
    }
  },
  "params": [
    {
      "name": "hlState",
      "value": "All"
    }
  ]
}