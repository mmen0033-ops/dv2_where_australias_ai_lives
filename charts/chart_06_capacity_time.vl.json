{
  "width": 540,
  "height": 320,
  "title": {
    "text": "Cumulative capacity over time",
    "subtitle": "Each line marks the year a major hyperscaler launched its first Australian region"
  },
  "data": {
    "url": "data/data_centres.csv"
  },
  "transform": [
    {
      "calculate": "+datum.year_opened",
      "as": "year"
    },
    {
      "aggregate": [
        {
          "op": "sum",
          "field": "capacity_mw",
          "as": "year_mw"
        }
      ],
      "groupby": [
        "year"
      ]
    },
    {
      "window": [
        {
          "op": "sum",
          "field": "year_mw",
          "as": "cumulative_mw"
        }
      ],
      "sort": [
        {
          "field": "year"
        }
      ]
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "area",
        "color": "#E0584F",
        "opacity": 0.18,
        "interpolate": "monotone"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative",
          "axis": {
            "format": "d",
            "values": [
              2005,
              2010,
              2015,
              2020,
              2025
            ]
          },
          "scale": {
            "domain": [
              2000,
              2026
            ]
          }
        },
        "y": {
          "field": "cumulative_mw",
          "type": "quantitative",
          "title": "Cumulative capacity (MW)",
          "axis": {
            "format": ",.0f"
          }
        }
      }
    },
    {
      "mark": {
        "type": "line",
        "color": "#E0584F",
        "strokeWidth": 2,
        "interpolate": "monotone"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative",
          "scale": {
            "domain": [
              2000,
              2026
            ]
          },
          "axis": {
            "format": "d"
          }
        },
        "y": {
          "field": "cumulative_mw",
          "type": "quantitative",
          "axis": {
            "format": ",.0f"
          }
        },
        "tooltip": [
          {
            "field": "year",
            "type": "quantitative",
            "title": "Year",
            "format": "d"
          },
          {
            "field": "year_mw",
            "type": "quantitative",
            "title": "MW added",
            "format": ".1f"
          },
          {
            "field": "cumulative_mw",
            "type": "quantitative",
            "title": "Cumulative (MW)",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "year": 2012,
            "y": 60,
            "label": "AWS Sydney"
          },
          {
            "year": 2014,
            "y": 200,
            "label": "Azure Sydney"
          },
          {
            "year": 2017,
            "y": 350,
            "label": "Google Cloud"
          },
          {
            "year": 2022,
            "y": 800,
            "label": "AWS Melbourne"
          },
          {
            "year": 2024,
            "y": 1300,
            "label": "Azure Melbourne"
          }
        ]
      },
      "mark": {
        "type": "rule",
        "color": "#1A1A1A",
        "strokeDash": [
          2,
          2
        ],
        "opacity": 0.4
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative",
          "axis": {
            "format": "d"
          }
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "year": 2012,
            "y": 60,
            "label": "AWS Sydney"
          },
          {
            "year": 2014,
            "y": 220,
            "label": "Azure Sydney"
          },
          {
            "year": 2017,
            "y": 380,
            "label": "Google Cloud"
          },
          {
            "year": 2022,
            "y": 830,
            "label": "AWS Melbourne"
          },
          {
            "year": 2024,
            "y": 1330,
            "label": "Azure Melbourne"
          }
        ]
      },
      "mark": {
        "type": "text",
        "fontSize": 9,
        "color": "#1A1A1A",
        "align": "left",
        "dx": 4,
        "fontWeight": 500
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative",
          "axis": {
            "format": "d"
          }
        },
        "y": {
          "field": "y",
          "type": "quantitative"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    }
  ],
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "config": {
    "background": "transparent",
    "view": {
      "stroke": null
    },
    "font": "Hanken Grotesk, system-ui, sans-serif",
    "axis": {
      "labelFont": "Hanken Grotesk, system-ui, sans-serif",
      "labelFontSize": 11,
      "labelColor": "#6B6B68",
      "titleFont": "Hanken Grotesk, system-ui, sans-serif",
      "titleFontSize": 11,
      "titleColor": "#1A1A1A",
      "titleFontWeight": 500,
      "domain": false,
      "ticks": false,
      "grid": true,
      "gridColor": "#E5E2D9",
      "gridOpacity": 0.5,
      "labelPadding": 6
    },
    "axisX": {
      "grid": false
    },
    "legend": {
      "labelFont": "Hanken Grotesk, system-ui, sans-serif",
      "labelFontSize": 11,
      "titleFont": "Hanken Grotesk, system-ui, sans-serif",
      "titleFontSize": 11,
      "titleFontWeight": 500,
      "padding": 0,
      "symbolType": "circle"
    },
    "title": {
      "font": "Hanken Grotesk, system-ui, sans-serif",
      "fontSize": 14,
      "fontWeight": 600,
      "color": "#1A1A1A",
      "anchor": "start",
      "offset": 8,
      "subtitleFont": "Hanken Grotesk, system-ui, sans-serif",
      "subtitleFontSize": 11,
      "subtitleColor": "#6B6B68"
    }
  },
  "autosize": {
    "type": "fit",
    "contains": "padding"
  }
}