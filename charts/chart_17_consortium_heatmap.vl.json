{
  "width": 540,
  "height": 280,
  "title": {
    "text": "Which countries build the cables connecting Australia",
    "subtitle": "Cells show which country's firms participate in each cable's consortium"
  },
  "data": {
    "url": "data/consortium.json"
  },
  "mark": {
    "type": "rect",
    "stroke": "white",
    "strokeWidth": 1.5,
    "cornerRadius": 2
  },
  "encoding": {
    "x": {
      "field": "cable_name",
      "type": "nominal",
      "sort": {
        "field": "cable_year"
      },
      "title": null,
      "axis": {
        "labelAngle": -40,
        "labelFontSize": 9,
        "labelLimit": 150
      }
    },
    "y": {
      "field": "country",
      "type": "nominal",
      "sort": "-x",
      "title": null,
      "axis": {
        "labelFontWeight": 500,
        "labelColor": "#1A1A1A"
      }
    },
    "color": {
      "field": "country",
      "type": "nominal",
      "scale": {
        "domain": [
          "US",
          "AU",
          "UK",
          "SG",
          "NZ",
          "Japan",
          "China",
          "Indonesia",
          "USA",
          "Australia",
          "Singapore"
        ],
        "range": [
          "#E0584F",
          "#1F8B8A",
          "#5B7FA6",
          "#F39C42",
          "#8A867C",
          "#9B5A8C",
          "#7A5547",
          "#C9A227",
          "#E0584F",
          "#1F8B8A",
          "#F39C42"
        ]
      },
      "legend": null
    },
    "tooltip": [
      {
        "field": "country",
        "type": "nominal"
      },
      {
        "field": "cable_name",
        "type": "nominal"
      },
      {
        "field": "cable_year",
        "type": "quantitative",
        "title": "Year active",
        "format": "d"
      }
    ]
  },
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "config": {
    "background": "transparent",
    "view": {
      "stroke": null
    },
    "font": "Hanken Grotesk, system-ui, sans-serif",
    "axis": {
      "labelFont": "Hanken Grotesk, system-ui, sans-serif",
      "labelFontSize": 11,
      "labelColor": "#6B6B68",
      "titleFont": "Hanken Grotesk, system-ui, sans-serif",
      "titleFontSize": 11,
      "titleColor": "#1A1A1A",
      "titleFontWeight": 500,
      "domain": false,
      "ticks": false,
      "grid": true,
      "gridColor": "#E5E2D9",
      "gridOpacity": 0.5,
      "labelPadding": 6
    },
    "axisX": {
      "grid": false
    },
    "legend": {
      "labelFont": "Hanken Grotesk, system-ui, sans-serif",
      "labelFontSize": 11,
      "titleFont": "Hanken Grotesk, system-ui, sans-serif",
      "titleFontSize": 11,
      "titleFontWeight": 500,
      "padding": 0,
      "symbolType": "circle"
    },
    "title": {
      "font": "Hanken Grotesk, system-ui, sans-serif",
      "fontSize": 14,
      "fontWeight": 600,
      "color": "#1A1A1A",
      "anchor": "start",
      "offset": 8,
      "subtitleFont": "Hanken Grotesk, system-ui, sans-serif",
      "subtitleFontSize": 11,
      "subtitleColor": "#6B6B68"
    }
  },
  "autosize": {
    "type": "fit",
    "contains": "padding"
  }
}