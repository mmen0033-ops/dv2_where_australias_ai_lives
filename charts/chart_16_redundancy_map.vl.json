          "type": "topojson",
          "feature": "au_sa4"
        }
      },
      "mark": {
        "type": "geoshape",
        "stroke": "#FFFFFF",
        "strokeWidth": 0.25,
        "clip": true
      },
      "encoding": {
        "color": {
          "field": "cabletier",
          "type": "ordinal",
          "scale": {
            "domain": [
              "1-2 cables",
              "3-5 cables",
              "6-8 cables",
              "9+ cables"
            ],
            "range": [
              "#DCE7F1",
              "#9CBBD9",
              "#5184B8",
              "#234E82"
            ]
          },
          "title": "Cables at nearest gateway",
          "legend": {
            "orient": "bottom",
            "direction": "horizontal",
            "offset": 8,
            "symbolType": "square"
