            "field": "properties.label",
            "type": "nominal",
            "title": "Region"
          },
          {
            "field": "properties.state",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "properties.cable_count",
            "type": "quantitative",
            "title": "Cables at gateway"
          },
          {
            "field": "properties.population",
            "type": "quantitative",
            "title": "Population",
            "format": ","
          }
        ]
      },
      "transform": [
        {
          "calculate": "datum.properties.cable_count == null ? 'No data' : datum.properties.cable_count < 3 ? '1-2 cables' : datum.properties.cable_count < 6 ? '3-5 cables' : datum.properties.cable_count < 9 ? '6-8 cables' : '9+ cables'",
          "as": "cabletier"
        }
