        "fontSize": 10.5,
        "fontWeight": 700,
        "dy": 0,
        "align": "center",
        "stroke": "#FFFFFF",
        "strokeWidth": 3,
        "lineJoin": "round",
        "fill": "#FFFFFF",
        "clip": true
      },
      "encoding": {
        "longitude": {
          "field": "lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "lat",
          "type": "quantitative"
        },
        "text": {
          "field": "city",
          "type": "nominal"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "city": "Sydney",
            "lat": -33.6,
