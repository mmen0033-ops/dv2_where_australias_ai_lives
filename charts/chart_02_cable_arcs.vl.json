{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 560,
  "height": 440,
  "title": {
    "text": "Submarine cables connecting Australia",
    "subtitle": "Great-circle paths to overseas landing points. Line width shows capacity in Tbps; hover any cable to trace it.",
    "anchor": "start"
  },
  "layer": [
    {
      "data": {
        "sphere": true
      },
      "mark": {
        "type": "geoshape",
        "fill": "#E9ECEE",
        "clip": true
      }
    },
    {
      "data": {
        "graticule": {
          "step": [
            20,
            20
          ]
        }
      },
      "mark": {
        "type": "geoshape",
        "filled": false,
        "stroke": "#D8DAD6",
        "strokeWidth": 0.4,
        "strokeOpacity": 0.85,
        "clip": true
      }
    },
    {
      "data": {
        "url": "data/world-atlas-countries-110m.json",
        "format": {
          "type": "topojson",
          "feature": "countries"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#ECEBE4",
        "stroke": "#C9C3B5",
        "strokeWidth": 0.4,
        "clip": true
      }
    },
    {
      "data": {
        "url": "data/cable_arcs_gc.json"
      },
      "params": [
        {
          "name": "cable_hl",
          "select": {
            "type": "point",
            "on": "mouseover",
            "fields": [
              "name"
            ],
            "clear": "mouseout"
          }
        }
      ],
      "mark": {
        "type": "line",
        "strokeCap": "round",
        "strokeJoin": "round",
        "clip": true,
        "interpolate": "linear"
      },
      "encoding": {
        "longitude": {
          "field": "lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "lat",
          "type": "quantitative"
        },
        "order": {
          "field": "order",
          "type": "quantitative"
        },
        "detail": {
          "field": "name",
          "type": "nominal"
        },
        "size": {
          "field": "capacity_tbps",
          "type": "quantitative",
          "scale": {
            "range": [
              0.8,
              4.5
            ]
          },
          "title": [
            "Capacity (Tbps)"
          ],
          "legend": {
            "orient": "bottom",
            "direction": "horizontal",
            "offset": 10
          }
        },
        "color": {
          "field": "year_active",
          "type": "quantitative",
          "scale": {
            "range": ["#BBCFE4", "#6E97C4", "#3C6BA6", "#16386B"]
          },
          "title": [
            "Active since (year)"
          ],
          "legend": {
            "orient": "bottom",
            "direction": "horizontal",
            "offset": 10,
            "format": "d",
            "gradientLength": 120
          }
        },
        "opacity": {
          "condition": {
            "param": "cable_hl",
            "value": 0.95,
            "empty": true
          },
          "value": 0.35
        },
        "tooltip": [
          {
            "field": "name",
            "type": "nominal",
            "title": "Cable"
          },
          {
            "field": "capacity_tbps",
            "type": "quantitative",
            "title": "Capacity (Tbps)",
            "format": ",.1f"
          },
          {
            "field": "year_active",
            "type": "quantitative",
            "title": "Active since",
            "format": "d"
          },
          {
            "field": "endpoint_name",
            "type": "nominal",
            "title": "Toward"
          },
          {
            "field": "consortium",
            "type": "nominal",
            "title": "Operated by"
          }
        ]
      }
    },
    {
