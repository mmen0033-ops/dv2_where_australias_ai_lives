  "transform": [
    {
      "calculate": "indexof(['Amazon AWS','AirTrunk','Equinix','Microsoft','Google'], datum.operator) >= 0 ? 'Foreign Hyperscaler' : (indexof(['Centersquare','DCI Data Centers','Global Switch'], datum.operator) >= 0 ? 'Foreign' : 'Domestic')",
      "as": "owner_type"
    }
  ],
  "mark": {
    "type": "bar",
    "stroke": "white",
    "strokeWidth": 0.5
  },
  "encoding": {
    "y": {
      "field": "cable_name",
      "type": "nominal",
      "sort": {
        "field": "cable_total",
        "op": "max",
        "order": "descending"
      },
      "title": null,
      "axis": {
        "labelFontWeight": 500,
        "labelColor": "#1A1A1A",
        "labelLimit": 200
      }
    },
    "x": {
      "field": "estimated_tbps",
      "type": "quantitative",
      "stack": true,
      "title": "Capacity carried (Tbps)",
      "axis": {
        "format": ",.0f",
        "grid": false
      }
    },
    "color": {
      "field": "owner_type",
      "type": "nominal",
      "scale": {
        "domain": ["Foreign Hyperscaler", "Foreign", "Domestic"],
        "range": ["#E0584F", "#F39C42", "#1F8B8A"]
      },
      "title": "Operator ownership",
      "legend": {
        "orient": "bottom",
        "columns": 3,
        "symbolType": "square",
        "labelLimit": 160
      }
    },
    "order": {
      "aggregate": "sum",
      "field": "estimated_tbps",
      "sort": "descending"
    },
    "opacity": {
      "condition": {
        "test": "op_sel == 'All operators' || datum.operator == op_sel",
        "value": 1
      },
      "value": 0.12
    },
    "tooltip": [
      {
        "field": "cable_name",
        "title": "Cable"
      },
      {
        "field": "operator",
        "title": "Operator"
      },
      {
        "field": "owner_type",
        "title": "Ownership"
      },
      {
        "field": "estimated_tbps",
        "title": "Capacity (Tbps)",
        "format": ",.1f"
      },
      {
        "field": "operator_share_pct",
        "title": "Share of cable (%)",
        "format": ",.0f"
      }
    ]
  },
  "config": {
    "background": "transparent",
    "view": {
      "stroke": null
    },
    "font": "Hanken Grotesk, system-ui, sans-serif",
